# Language statistics tuning for GitHub Linguist
# SQL is the primary language; Python and Jupyter are secondary.

# SQL — primary language
*.sql linguist-detectable=true
sql/** linguist-language=SQL

# Python — counted as secondary language
*.py linguist-detectable=true

# Jupyter notebooks — counted (overriding default JSON detection)
*.ipynb linguist-detectable=true
*.ipynb linguist-language=Python

# Markdown — documentation
*.md linguist-documentation
