# Language statistics tuning for GitHub Linguist
# This is a SQL-first project; keep the language bar representative.

# Do not count Jupyter notebooks toward the language stats (they are large JSON).
*.ipynb linguist-documentation

# Make sure SQL files are detected and counted.
*.sql linguist-detectable=true
sql/** linguist-language=SQL

# Treat markdown docs as documentation.
*.md linguist-documentation
